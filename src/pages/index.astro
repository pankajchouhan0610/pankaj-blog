---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const postFiles = import.meta.glob('../content/blogs/*.md', { eager: true });
const sorted = Object.values(postFiles).sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
const linkedInUrl = 'https://www.linkedin.com/in/pankajchouhan0610/';
---
<BaseLayout title="Home">
  <Nav />
  <main class="home-main">
    <!-- Two-column layout: writing list (left) + profile card (right), stacks on small screens -->
    <div class="home-layout">
      <section class="posts-column" aria-label="Recent writing">
        <div class="post-list">
          {sorted.map(post => (
            <a href={`/blogs/${post.frontmatter.slug}`} class="post-row">
              <span class="post-date">{new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              <span class="post-title">{post.frontmatter.title}</span>
            </a>
          ))}
        </div>
      </section>

      <aside class="profile-card" aria-label="About">
        <img src="/profile.png" alt="" class="avatar" />
        <div class="profile-text">
          <h1>Pankaj Chouhan</h1>
          <p class="tagline">Engineer and writer. Writing about systems, web development, and things I find interesting.</p>
          <!-- Icon link under bio: SVG + aria-label for screen readers -->
          <a
            href={linkedInUrl}
            class="profile-linkedin"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pankaj Chouhan on LinkedIn"
          >
            <svg
              class="linkedin-svg"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Page shell — body background comes from BaseLayout only; no extra fills here */
  .home-main {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .home-layout {
    display: grid;
    grid-template-columns: 1fr minmax(288px, 360px);
    gap: 1.25rem;
    align-items: start;
  }

  /* Post list: date column (muted, smaller) vs title (stronger, larger); hover unchanged */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    margin: 0 -1.25rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    border-radius: 10px;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .post-row:hover {
    background: var(--code-bg);
    border-color: var(--border);
  }

  .post-row:hover .post-date {
    color: color-mix(in srgb, var(--text-muted) 85%, var(--text));
  }

  .post-date {
    flex-shrink: 0;
    width: 6.875rem;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--text-muted);
    text-align: right;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
  }

  .post-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.025em;
  }

  /* Profile block: layout only; inherits page background */
  .profile-card {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding: 0 0 0 0.25rem;
  }

  /* Avatar sized to read well beside name + bio without crowding the column */
  .profile-card .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .profile-text h1 {
    font-size: 1.35rem;
    font-weight: 800;
    margin-bottom: 0.4rem;
    color: var(--text);
    line-height: 1.2;
  }

  .profile-text .tagline {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0 0 0.65rem;
  }

  .profile-linkedin {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
    padding: 0.3rem;
    margin-left: -0.3rem;
    border-radius: 8px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .profile-linkedin:hover {
    color: var(--text);
    background: var(--code-bg);
  }

  .profile-linkedin:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .linkedin-svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }

  /* Narrow view: single column, intro first */
  @media (max-width: 720px) {
    .home-layout {
      grid-template-columns: 1fr;
    }

    .profile-card {
      order: -1;
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .post-date {
      width: 6.25rem;
      font-size: 0.78rem;
    }

    .post-title {
      font-size: 1.05rem;
    }
  }
</style>
