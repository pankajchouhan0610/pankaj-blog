---
  const year = new Date().getFullYear();
---
  <footer>
    <div class="footer-inner">
      <div class="footer-links">
        <div>
          <strong>Writing</strong>
          <a href="/blogs">Blogs</a>
          <a href="/notes">Notes</a>
        </div>
        <div>
          <strong>Connect</strong>
          <a href="https://linkedin.com/in/pankajchouhan0610" target="_blank">LinkedIn</a>
        </div>
      </div>
      <p class="copy">© Pankaj Chouhan, {year}</p>
    </div>
  </footer>

  <style>
    footer { border-top: 1px solid var(--border); margin-top: 4rem; padding: 3rem 1.5rem; }
  .footer-inner { max-width: 720px; margin: 0 auto; }
  .footer-links { display: flex; gap: 4rem; margin-bottom: 2rem; }
  .footer-links div { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links strong { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem; }
  .footer-links a { color: var(--text-muted); font-size: 0.9rem; text-decoration: none; }
  .footer-links a:hover { color: var(--text); }
  .copy { font-size: 0.85rem; color: var(--text-muted); }
</style>
