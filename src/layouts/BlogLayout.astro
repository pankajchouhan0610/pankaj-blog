---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
const { title, description, date, tags = [] } = frontmatter;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main>
    <article>
      <header class="article-header">
        <div class="meta">
          <time>{formattedDate}</time>
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <h1>{title}</h1>
        {description && <p class="description">{description}</p>}
      </header>
      <div class="content">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Article shell: comfortable vertical rhythm */
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.25rem 1.5rem 4rem;
  }

  /* Space after title block — whitespace only, no rule */
  .article-header {
    margin-bottom: 3.5rem;
    padding-bottom: 0.25rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  time {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .tag {
    font-size: 0.75rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 2px 8px;
    border-radius: 99px;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.25;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .description {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 0;
  }

  /*
   * Markdown `---` becomes <hr>. Use spacing only — no full-width line
   * so sections breathe without repeating a thick divider.
   */
  .content hr {
    border: none;
    height: 0;
    margin: 3rem 0;
    background: transparent;
  }

  .content {
    font-size: 1.05rem;
    line-height: 1.82;
  }

  .content > :first-child {
    margin-top: 0;
  }

  .content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 3.75rem 0 1.15rem;
    line-height: 1.3;
    padding-top: 0.5rem;
  }

  .content h2:first-child {
    margin-top: 0;
  }

  .content h2 + h3 {
    margin-top: 1.35rem;
  }

  .content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2.65rem 0 1rem;
    line-height: 1.35;
  }

  .content p {
    margin: 0 0 1.7rem;
  }

  .content li > p {
    margin: 0 0 0.55rem;
  }

  .content li > p:last-child {
    margin-bottom: 0;
  }

  .content ol {
    margin: 0 0 2rem;
    padding-left: 1.5rem;
  }

  .content ol li {
    margin-bottom: 0.7rem;
    padding-left: 0.4rem;
  }

  .content ul {
    list-style: none;
    margin: 0 0 2rem;
    padding-left: 0;
  }

  .content ul li {
    position: relative;
    padding-left: 1.35rem;
    margin-bottom: 0.75rem;
    line-height: 1.72;
  }

  .content ul li::before {
    content: '\2013';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--text-muted);
    font-weight: 500;
    opacity: 0.8;
    pointer-events: none;
  }

  .content ul ul {
    margin: 0.65rem 0 0.6rem;
  }

  .content ul ul li {
    padding-left: 1.2rem;
    margin-bottom: 0.55rem;
  }

  .content ul ul li::before {
    content: '\2013';
    opacity: 0.55;
    font-weight: 400;
  }

  .content blockquote {
    border-left: 3px solid var(--accent);
    padding: 1rem 0 1rem 1.4rem;
    margin: 2.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .content blockquote p:last-child {
    margin-bottom: 0;
  }

  .content img {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .content pre {
    margin: 2rem 0 2.15rem;
  }

  .content a {
    color: var(--accent);
  }

  .content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95em;
    margin: 2rem 0 2.15rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .content th,
  .content td {
    padding: 0.75rem 0.9rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .content tr:last-child td {
    border-bottom: none;
  }

  .content th {
    background: var(--code-bg);
    font-weight: 600;
    color: var(--text);
  }
</style>
